# Database — SQLite (local dev). For production, swap to a Postgres
# URL (Neon / Supabase / Turso) and update `provider` in
# prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Admin seed (used by prisma/seed.ts on first run — change before deploying)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!2025"
ADMIN_NAME="Portfolio Admin"

# UploadThing — https://uploadthing.com
UPLOADTHING_TOKEN=""
UPLOADTHING_SECRET=""

# Resend — https://resend.com (optional — emails skip silently if missing)
RESEND_API_KEY=""
RESEND_FROM="Portfolio <noreply@yourdomain.com>"
# Comma-separate multiple recipients for booking notifications.
ADMIN_NOTIFY_EMAIL="you@yourdomain.com"
# Public logo URL shown in the booking email header (must be publicly reachable).
EMAIL_LOGO_URL=""

# Google Calendar / Meet — generates a unique Meet link per booking (optional).
# Enable the Calendar API + create an OAuth client at console.cloud.google.com,
# then visit /api/google/connect once to obtain GOOGLE_REFRESH_TOKEN.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"
GOOGLE_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID="primary"
BOOKING_TIMEZONE="Asia/Amman"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
