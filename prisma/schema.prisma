generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String
  role           UserRole @default(ADMIN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum UserRole {
  ADMIN
}

// ============================================================
// SINGLETONS (one row each, upserted by id = "singleton")
// ============================================================

model SiteSettings {
  id              String   @id @default("singleton")
  siteName        String   @default("Portfolio")
  defaultLocale   String   @default("en")
  primaryColor    String   @default("#0a0a0a")
  accentColor     String   @default("#8b5cf6")
  seoTitleEn      String   @default("UX/UI Designer Portfolio")
  seoTitleAr      String   @default("معرض أعمال مصمم تجربة المستخدم")
  seoDescEn       String   @default("Premium UX/UI design portfolio")
  seoDescAr       String   @default("معرض أعمال احترافي لتصميم تجربة وواجهة المستخدم")
  ogImage         String?
  updatedAt       DateTime @updatedAt
}

model HeroContent {
  id              String   @id @default("singleton")
  nameEn          String
  nameAr          String
  titleEn         String
  titleAr         String
  introEn         String
  introAr         String
  primaryCtaLabelEn String @default("View Projects")
  primaryCtaLabelAr String @default("استعرض الأعمال")
  primaryCtaHref  String   @default("/projects")
  secondaryCtaLabelEn String @default("Book a Meeting")
  secondaryCtaLabelAr String @default("احجز اجتماعاً")
  secondaryCtaHref String  @default("/contact")
  profileImage    String?
  updatedAt       DateTime @updatedAt
}

model AboutContent {
  id              String   @id @default("singleton")
  headlineEn      String
  headlineAr      String
  biographyEn     String
  biographyAr     String
  philosophyEn    String
  philosophyAr    String
  experienceSummaryEn String
  experienceSummaryAr String
  profileImage    String?
  highlights      Json     @default("[]") // [{ titleEn, titleAr, descEn, descAr }]
  updatedAt       DateTime @updatedAt
}

model ContactCta {
  id              String   @id @default("singleton")
  headlineEn      String   @default("Let's build something exceptional")
  headlineAr      String   @default("لنبنِ شيئاً استثنائياً معاً")
  subtitleEn      String   @default("Available for select projects.")
  subtitleAr      String   @default("متاح لمشاريع مختارة.")
  ctaLabelEn      String   @default("Book a meeting")
  ctaLabelAr      String   @default("احجز اجتماعاً")
  ctaHref         String   @default("/contact")
  updatedAt       DateTime @updatedAt
}

model FooterContent {
  id              String   @id @default("singleton")
  bioEn           String   @default("UX/UI Designer crafting calm, premium digital products.")
  bioAr           String   @default("مصمم واجهات وتجربة مستخدم يصنع منتجات رقمية هادئة ومميزة.")
  email           String   @default("hello@example.com")
  copyrightEn     String   @default("© All rights reserved.")
  copyrightAr     String   @default("© جميع الحقوق محفوظة.")
  updatedAt       DateTime @updatedAt
}

// ============================================================
// COLLECTIONS
// ============================================================

model Skill {
  id          String   @id @default(cuid())
  nameEn      String
  nameAr      String
  category    String   @default("Design")
  level       Int      @default(80)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id          String   @id @default(cuid())
  name        String
  iconUrl     String?
  category    String   @default("Design")
  order       Int      @default(0)
  projects    ProjectTool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id              String   @id @default(cuid())
  slug            String   @unique
  titleEn         String
  titleAr         String
  shortDescEn     String
  shortDescAr     String
  fullDescEn      String
  fullDescAr      String
  coverImage      String?
  category        String   @default("UX/UI")
  roleEn          String   @default("Lead Designer")
  roleAr          String   @default("مصمم رئيسي")
  timelineEn      String   @default("4 weeks")
  timelineAr      String   @default("٤ أسابيع")
  client          String?
  projectType     String   @default("Case Study")
  liveLink        String?
  behanceLink     String?
  dribbbleLink    String?
  figmaLink       String?
  isFeatured      Boolean  @default(false)
  isPublished     Boolean  @default(true)
  order           Int      @default(0)
  images          ProjectImage[]
  tools           ProjectTool[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([isFeatured])
  @@index([isPublished])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  altEn     String   @default("")
  altAr     String   @default("")
  order     Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectTool {
  projectId String
  toolId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tool      Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([projectId, toolId])
}

model CaseStudy {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleAr     String
  summaryEn   String
  summaryAr   String
  coverImage  String?
  client      String?
  roleEn      String   @default("Lead UX Designer")
  roleAr      String   @default("مصمم تجربة المستخدم الرئيسي")
  timelineEn  String   @default("8 weeks")
  timelineAr  String   @default("٨ أسابيع")
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  sections    CaseStudySection[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CaseStudySection {
  id          String   @id @default(cuid())
  caseStudyId String
  type        CaseStudySectionType @default(CUSTOM)
  order       Int      @default(0)
  titleEn     String
  titleAr     String
  bodyEn      String   @default("")
  bodyAr      String   @default("")
  blocks      Json     @default("[]")
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId])
}

enum CaseStudySectionType {
  OVERVIEW
  PROBLEM
  GOAL
  ROLE
  TIMELINE
  RESEARCH
  INTERVIEWS
  AFFINITY
  PERSONAS
  JOURNEY
  FLOW
  WIREFRAMES
  DESIGN_SYSTEM
  FINAL_UI
  USABILITY
  ITERATIONS
  RESULTS
  LEARNINGS
  CUSTOM
}

model Service {
  id              String   @id @default(cuid())
  icon            String   @default("Sparkles")
  titleEn         String
  titleAr         String
  descriptionEn   String
  descriptionAr   String
  deliverables    Json     @default("[]") // [{ en, ar }]
  timelineEn      String   @default("2-4 weeks")
  timelineAr      String   @default("٢-٤ أسابيع")
  ctaLabelEn      String   @default("Book a meeting")
  ctaLabelAr      String   @default("احجز اجتماعاً")
  isActive        Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  roleEn      String
  roleAr      String
  company     String
  locationEn  String   @default("")
  locationAr  String   @default("")
  descriptionEn String @default("")
  descriptionAr String @default("")
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  author      String
  roleEn      String
  roleAr      String
  company     String
  avatarUrl   String?
  quoteEn     String
  quoteAr     String
  rating      Int      @default(5)
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
}

// ============================================================
// BOOKING
// ============================================================

model MeetingType {
  id              String   @id @default(cuid())
  slug            String   @unique
  nameEn          String
  nameAr          String
  descriptionEn   String
  descriptionAr   String
  durationMinutes Int      @default(30)
  isActive        Boolean  @default(true)
  order           Int      @default(0)
  bookings        Booking[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AvailabilityRule {
  id         String  @id @default(cuid())
  dayOfWeek  Int     // 0 = Sunday ... 6 = Saturday
  startTime  String  // "HH:mm" 24h
  endTime    String  // "HH:mm" 24h
  isActive   Boolean @default(true)

  @@index([dayOfWeek])
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Booking {
  id              String         @id @default(cuid())
  meetingTypeId   String
  date            DateTime       // date portion only matters
  startTime       String         // "HH:mm"
  durationMinutes Int
  name            String
  email           String
  phone           String?
  company         String?
  message         String?
  status          BookingStatus  @default(PENDING)
  meetingType     MeetingType    @relation(fields: [meetingTypeId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([date])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
